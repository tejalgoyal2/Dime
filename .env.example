# Supabase (required at build time for client bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gemini AI (server-only)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# App config (server-only)
INVITE_CODE=your-invite-code
ADMIN_EMAIL=your-admin@spendlog.app

# Upstash Redis — rate limiting (server-only)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Quick Add API — Apple Shortcuts / automation (server-only)
QUICK_ADD_TOKEN=your-secret-bearer-token
QUICK_ADD_USER_ID=your-supabase-user-uuid
