# Supabase (required at build time for client bundle)
# Also add as GitHub Secrets for CI: NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gemini AI (server-only, set in Cloudflare Pages env vars)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# App config (server-only, set in Cloudflare Pages env vars)
INVITE_CODE=your-invite-code
ADMIN_EMAIL=your-admin@spendlog.app

# Upstash Redis — rate limiting (server-only, set in Cloudflare Pages env vars)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Quick Add API — Apple Shortcuts / automation (server-only)
QUICK_ADD_TOKEN=your-secret-bearer-token
QUICK_ADD_USER_ID=your-supabase-user-uuid

# GitHub Actions Secrets (not in .env, add to repo settings):
# CLOUDFLARE_API_TOKEN — Cloudflare API token with Pages edit permission
# CLOUDFLARE_ACCOUNT_ID — Your Cloudflare account ID
